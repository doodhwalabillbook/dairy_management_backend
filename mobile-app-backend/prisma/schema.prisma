// Dairy Management Backend — Prisma Schema
// Redesigned: CustomerMilkConfig versioning (effectiveFrom pattern)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  VENDOR
  ADMIN
}

enum VendorStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMode {
  CASH
  UPI
  CARD
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  mobile    String   @unique @db.VarChar(15)
  name      String
  pinHash   String
  role      Role     @default(VENDOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor?
}

// ─── Company ─────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @unique @db.VarChar(255)
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  gstin     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendors Vendor[]
}

// ─── Vendor ──────────────────────────────────────────────────────────────────

model Vendor {
  id           String       @id @default(uuid()) @db.VarChar(36)
  companyId    String       @db.VarChar(36)
  userId       String?      @unique @db.VarChar(36)
  name         String
  phone        String?
  mobileNumber String?      @unique @db.VarChar(15)
  email        String?
  area         String?
  address      String?
  status       VendorStatus @default(ACTIVE)
  isActive     Boolean      @default(true)
  createdBy    String?      @db.VarChar(36)
  updatedBy    String?      @db.VarChar(36)
  joinedAt     DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  company        Company        @relation(fields: [companyId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])
  customers      Customer[]
  milkDeliveries MilkDelivery[]
}

// ─── Area ────────────────────────────────────────────────────────────────────

model Area {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @unique
  description String?
  status      String   @default("ACTIVE")
  createdBy   String?  @db.VarChar(36)
  updatedBy   String?  @db.VarChar(36)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]
}

// ─── Customer (identity only — no config fields) ─────────────────────────────

model Customer {
  id               String   @id @default(uuid()) @db.VarChar(36)
  vendorId         String   @db.VarChar(36)
  areaId           String   @db.VarChar(36)
  name             String
  phone            String   @db.VarChar(15)
  address          String
  remainingAmount  Decimal  @default(0) @db.Decimal(10, 2)
  registrationDate DateTime @db.Date
  isActive         Boolean  @default(true)
  createdBy        String?  @db.VarChar(36)
  updatedBy        String?  @db.VarChar(36)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  vendor         Vendor               @relation(fields: [vendorId], references: [id])
  area           Area                 @relation(fields: [areaId], references: [id])
  milkConfigs    CustomerMilkConfig[]
  milkDeliveries MilkDelivery[]
  payments       Payment[]

  @@index([vendorId])
  @@index([areaId])
  @@index([phone, vendorId])
}

// ─── CustomerMilkConfig (versioned config — effectiveFrom pattern) ────────────

model CustomerMilkConfig {
  id              String   @id @default(uuid()) @db.VarChar(36)
  customerId      String   @db.VarChar(36)
  effectiveFrom   DateTime @db.Date
  morningQuantity Decimal  @db.Decimal(10, 2)
  eveningQuantity Decimal  @db.Decimal(10, 2)
  ratePerLiter    Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, effectiveFrom])
  @@index([customerId, effectiveFrom])
}

// ─── MilkDelivery (daily override / exception) ───────────────────────────────

model MilkDelivery {
  id              String   @id @default(uuid()) @db.VarChar(36)
  vendorId        String   @db.VarChar(36)
  customerId      String   @db.VarChar(36)
  date            DateTime @db.Date
  morningQuantity Decimal  @default(0) @db.Decimal(10, 2)
  eveningQuantity Decimal  @default(0) @db.Decimal(10, 2)
  isEdited        Boolean  @default(false)
  createdBy       String?  @db.VarChar(36)
  updatedBy       String?  @db.VarChar(36)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, date])
  @@index([customerId, date])
  @@index([vendorId, date])
}

// ─── Payment ─────────────────────────────────────────────────────────────────

model Payment {
  id          String      @id @default(uuid()) @db.VarChar(36)
  customerId  String      @db.VarChar(36)
  amountPaid  Decimal     @db.Decimal(10, 2)
  paymentDate DateTime    @db.Date
  month       Int
  year        Int
  paymentMode PaymentMode @default(CASH)
  notes       String?
  createdBy   String?     @db.VarChar(36)
  updatedBy   String?     @db.VarChar(36)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, month, year])
}

// ─── Product Catalog (unchanged) ─────────────────────────────────────────────

model ProductCategory {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @unique @db.VarChar(255)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  products Product[]
}

model Product {
  id          String   @id @default(uuid()) @db.VarChar(36)
  categoryId  String   @db.VarChar(36)
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id])
}
